## Color coding:
#########################
##  Main FRR: #f08080  red
##  Switches: #d0e0d0  gray
##  RIP:      #19e3d9  Cyan
##  RIPng:    #fcb314  dark yellow
##  OSPFv2:   #32b835  Green
##  OSPFv3:   #19e3d9  Cyan
##  ISIS IPv4 #fcb314  dark yellow
##  ISIS IPv6 #9a81ec  purple
##  BGP IPv4  #eee3d3  beige
##  BGP IPv6  #fdff00  yellow
##  host:     #4f4f4f  gray31
##### Colors (see http://www.color-hex.com/)

graph test_evpn_anycast_macvlan {
  label="test-evpn-anycast-macvlan";

  # Routers
  r1 [
    shape=doubleoctagon,
    label="r1",
    fillcolor="#f08080",
    style=filled,
  ];
  r2 [
    shape=doubleoctagon,
    label="r2",
    fillcolor="#f08080",
    style=filled,
  ];

  host11 [
    shape=rectangle,
    label="host11\n192.168.1.10/24",
    fillcolor="#4f4f4f",
    style=filled,
  ];
  host12 [
    shape=rectangle,
    label="host12\n192.168.2.10/24",
    fillcolor="#4f4f4f",
    style=filled,
  ];
  host21 [
    shape=rectangle,
    label="host21\n192.168.1.20/24",
    fillcolor="#4f4f4f",
    style=filled,
  ];
  host22 [
    shape=rectangle,
    label="host22\n192.168.2.20/24",
    fillcolor="#4f4f4f",
    style=filled,
  ];

  # Switches
  s11 [
    shape=oval,
    label="s11",
    fillcolor="#d0e0d0",
    style=filled,
  ];
  s12 [
    shape=oval,
    label="s12",
    fillcolor="#d0e0d0",
    style=filled,
  ];
  s21 [
    shape=oval,
    label="s21",
    fillcolor="#d0e0d0",
    style=filled,
  ];
  s22 [
    shape=oval,
    label="s22",
    fillcolor="#d0e0d0",
    style=filled,
  ];

  # Connections
  r1 -- s11
  r1 -- s12
  r2 -- s21
  r2 -- s22
  s11 -- host11
  s12 -- host12
  s21 -- host21
  s22 -- host22
}
